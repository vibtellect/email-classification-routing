# AWS Bedrock Credentials (REQUIRED)
# Get these from AWS IAM > Users > Your User > Security Credentials
# See: iam/n8n-automation-policy.json for required permissions
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=eu-central-1

# IMAP Integration (optional, for live email processing)
# For Gmail: Create an App Password (not your main account password!)
# See: https://support.google.com/accounts/answer/185833
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-test-email@gmail.com
IMAP_PASS=xxxx-xxxx-xxxx-xxxx

# Slack Integration (optional)
# Create an Incoming Webhook: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR_WORKSPACE/YOUR_CHANNEL/YOUR_TOKEN

# Slack Channel Routing (optional, if using Slack integration)
SLACK_CHANNEL_VERTRIEB=#vertrieb
SLACK_CHANNEL_SUPPORT=#support
SLACK_CHANNEL_HR=#hr
SLACK_CHANNEL_BUCHHALTUNG=#buchhaltung

# n8n Configuration (usually no need to change)
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
GENERIC_TIMEZONE=Europe/Berlin
